{
  "extends": "expo/tsconfig.base.json",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./app/*"
      ],
      "@cteno/client-ui": ["../../packages/client-ui/src/index.ts"],
      "@cteno/client-ui/*": ["../../packages/client-ui/src/*"],
      "@cteno/client-sync": ["../../packages/client-sync/src/index.ts"],
      "@cteno/client-sync/*": ["../../packages/client-sync/src/*"],
      "@cteno/client-agent-ui": ["../../packages/client-agent-ui/src/index.ts"],
      "@cteno/client-agent-ui/*": ["../../packages/client-agent-ui/src/*"],
      "@cteno/client-a2ui": ["../../packages/client-a2ui/src/index.ts"],
      "@cteno/client-a2ui/*": ["../../packages/client-a2ui/src/*"],
      "hello-world": [ "../../hello-world" ]
    },
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "incremental": true,
    "plugins": [
      {
        "name": "expo-router/typescript-plugin"
      }
    ]
  },
  "include": [
    "index.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "nativewind-env.d.ts"
  ],
  "exclude": [
    "app/trash/**/*",
    "node_modules",
    "desktop/target/**/*",
    "src-backup-20260207/**/*"
  ]
}
