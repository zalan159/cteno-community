{
  "$schema": "https://schema.tauri.app/capabilities/2",
  "identifier": "skill-store",
  "description": "Capabilities for Skill Store webview window",
  "remote": {
    "urls": [
      "https://skillsmp.com/*",
      "https://*.skillsmp.com/*"
    ]
  },
  "windows": ["skill-store"],
  "permissions": [
    "core:default",
    "deep-link:default",
    "core:window:allow-start-dragging"
  ]
}
